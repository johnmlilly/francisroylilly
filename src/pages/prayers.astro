---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts.ts";

const title = `Prayers | ${SITE_TITLE}`;
---

<BaseLayout title={title} description={SITE_DESCRIPTION}>
  <!-- Intro Section -->
  <section class="intro">
    <div class="container">
      <h1>Pray With Us</h1>
      <p>
        Throughout Francis’s journey, prayer has been at the center of
        everything. It's been instrumental in helping us rely on God, and we
        have witnessed the power of God working through the prayers of so many.
      </p>
      <p>
        We prayed to many different saints, some of whom we have a particular
        devotion to as a family, others who mean a lot to us, and some family
        members.
      </p>
    </div>
  </section>

  <!-- Saints Section -->
  <section class="saints">
    <div class="container">
      <h2>Our Litany of Saints</h2>
      <p>
        During some of our hardest moments, we prayed for the intercession of these incredible men and women who lead holy lives. 
      </p>
      <ul>
        <li>Roy Hollis</li>
        <li>Thomas Vanderwoude</li>
        <li>Pope Francis</li>
        <li>St. Therese</li>
        <li>Sts. Zelie and Louis</li>
        <li>St. Francis of Assisi</li>
        <li>St. Clare of Assisi</li>
        <li>St. Francis Xavier</li>
        <li>St. Francis De Sales</li>
        <li>St. John Baptist de Rossi</li>
        <li>St. Vitus</li>
        <li>St. Valentine</li>
        <li>Venerable Fulton Sheen</li>
        <li>St. Padre Pio of Pietrelcina</li>
        <li>Blessed John Licci</li>
        <li>Blessed Carlo Acutis</li>
        <li>St. Dymphna</li>
        <li>Baby Francis Kuisell</li>
        <li>Baby Samuel Kuisell</li>
        <li>Quenum Babies</li>
        <li>Baby Hyacinth Armstrong</li>
        <li>Baby Christopher Rea</li>
        <li>Baby Maximillian Pietrandrea</li>
        <li>Baby Sebastian Pietrandrea</li>
        <li>Baby Emmanuel Trebing</li>
        <li>John Francis Cannon</li>
        <li>Donald Lilly</li>
        <li>Mama Noone</li>
        <li>John Clem</li>
        <li>Nicolas Adinaro</li>
      </ul>

      <p class="highlight">
        We especially felt a deep connection to Tom Vander Woude — a father who
        gave everything in love. His witness meant a lot to us during this time.
      </p>
    </div>
  </section>

  <!-- Prayer Request Form -->
  <section class="prayer-form">
    <div class="container">
      <h2>Submit a Prayer Request</h2>
      <p>We would be honored to pray for you. Share your intention below.</p>

      <form
        name="prayer-requests"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="prayer-requests" />

        <p class="hidden">
          <label>
            Don’t fill this out if you're human:
            <input name="bot-field" />
          </label>
        </p>

        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" name="name" id="name" required />
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" name="email" id="email" required />
        </div>

        <div class="form-group">
          <label for="request">Prayer Request</label>
          <textarea name="request" id="request" rows="5" required></textarea>
        </div>

        <button type="submit">Submit Prayer</button>
      </form>
    </div>
  </section>
</BaseLayout>
<style>
  main {
    padding: 2rem 1rem;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
  }

  section {
    margin-bottom: 4rem;
  }

  h1,
  h2 {
    margin-bottom: 1rem;
  }

  p {
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .highlight {
    font-style: italic;
  }

  .form-group {
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
  }

  input,
  textarea {
    padding: 0.75rem;
    font-size: 1rem;
    margin-top: 0.5rem;
  }

  button {
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    cursor: pointer;
  }

  .hidden {
    display: none;
  }
</style>

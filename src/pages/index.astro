---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { Image, getImage } from "astro:assets";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import Timeline from "../components/Timeline.jsx";
import { getCollection } from "astro:content";
import heroImage from "../assets/images/francisroy-hero.jpeg";
import Cards from "../components/Cards.astro";

// Fetch all blog posts
const rawPosts = (await getCollection("blog")).sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
); // oldest → newest

// Optimize timeline images at build time
const posts = await Promise.all(
  rawPosts.map(async (post) => {
    if (!post.data.heroImage) return post;

    const optimized = await getImage({
      src: post.data.heroImage,
      width: 600,
      height: 600,
      format: "webp",
    });

    return {
      ...post,
      data: {
        ...post.data,
        heroImage: {
          src: optimized.src,
          width: optimized.width,
          height: optimized.height,
        },
      },
    };
  })
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <main>
      <!-- Hero Section -->
      <section class="hero">
        <div class="hero-content">
          <h1>Hi there! I'm Francis Roy Lilly</h1>
          <p>
            I was born April 1, 2025 and suffered a severe brain injury from
            HIE. I had an extremely bad prognosis to the point where my family thought they would have to say goodbye to me.
          </p>
          <p>
            <strong>But what happened next was a miracle.</strong> During Holy Week, I began to wake up and become more alert to the surprise of many. On Easter Sunday, I started breathing completely on my own. I went home not long after that.
          </p>
          <p>
            This site is a place to share my journey and how God continues to
            work in my life and in the life of my family.
          </p>
          <a href="#updates" class="cta">Updates</a>
        </div>
        <div class="hero-image">
          <Image
            width={583}
            height={389}
            src={heroImage}
            alt={SITE_TITLE}
            priority
          />
        </div>
      </section>
      <Cards />
      <section id="updates" class="timeline-section">
        <h2>Latest Updates</h2>
        <div class="timeline-wrapper">
          <Timeline client:only="react" posts={posts} />
        </div>
      </section>

      <Footer />
    </main>
  </body>
</html>

<style>
  .hero {
    display: grid;
    grid-template-columns: 0.75fr 1fr;
    align-items: center;
    padding: 2rem 2rem 4rem 2rem;
    gap: 1.5rem;
    margin-inline: auto;
  }

  .hero-content h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 600;
    color: var(--secondary-color);
  }

  .hero-content p {
    font-size: 1.2rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    color: #333;
  }

  .cta {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background-color: var(--primary-color);
    color: white;
    text-decoration: none;
    border-radius: 0.5rem;
    font-weight: 600;
    width: fit-content;
  }

  .cta:hover {
    background-color: var(--primary-color-hover);
  }

  .hero-image img {
    width: 100%;
    border-radius: 1rem;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  .timeline-section {
    padding-block: 2rem;
  }
  .timeline-wrapper {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
  }

  .timeline-section h2 {
    text-align: center;
    margin-bottom: 2rem;
    color: var(--primary-color);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-image {
      order: -1;
    }
    .hero {
      padding-block: 1.5rem;
    }
  }
</style>

---
import { Image, getImage } from "astro:assets";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts.ts";
import Timeline from "../components/Timeline.jsx";
import { getCollection } from "astro:content";
import heroImage from "../assets/images/francisroy-hero.jpeg";
import Cards from "../components/Cards.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

// Fetch all blog posts
const rawPosts = (await getCollection("blog")).sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
); // oldest → newest

// Optimize timeline images at build time
const posts = await Promise.all(
  rawPosts.map(async (post) => {
    if (!post.data.heroImage) return post;

    const optimized = await getImage({
      src: post.data.heroImage,
      width: 600,
      height: 600,
      format: "webp",
    });

    return {
      ...post,
      data: {
        ...post.data,
        heroImage: {
          src: optimized.src,
          width: optimized.width,
          height: optimized.height,
        },
      },
    };
  })
);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-image">
      <Image src={heroImage} alt={SITE_TITLE} fill priority class="hero-img" />
    </div>

    <div class="hero-overlay">
      <h1>Hi there! I'm Francis</h1>
    </div>
  </section>
  <!-- About Section -->
  <section class="about">
    <div>
      <h2>My Story</h2>

      <p>
        I was born on April 1, 2025 and suffered a severe brain injury from HIE (Hypoxic Ischemic Encephalopathy). I
        had an extremely poor outlook to the point where my family thought
        they would have to say goodbye to me.
      </p>

      <p>
        <strong>But God had other plans.</strong> During Holy Week, I
        began to wake up and become more alert to everyone's surprise. On Easter Sunday,
        I started breathing completely on my own. I went home not long after that.
      </p>

      <p>
        This site is a place to share my journey and how God continues to work
        in my life and in the life of my family.
      </p>

      <a href="#updates" class="cta">Updates</a>
    </div>
  </section>
<!--  <Cards /> -->
  <section id="updates" class="timeline-section">
    <h2>Latest Updates</h2>
    <div class="timeline-wrapper">
      <Timeline client:only="react" posts={posts} />
    </div>
  </section>
</BaseLayout>

<style>
  section {
    padding: 3rem 1.5rem;
  }

  .hero {
    position: relative;
    width: 100%;
    height: 75vh;
    min-height: 400px;
    overflow: hidden;
  }

  /* Makes image act like a background */
  .hero-image {
    position: absolute;
    inset: 0;
  }

  .hero-img {
    object-fit: cover;
    width: 100%;
    height: 100%;
    border-radius: initial;
  }

  /* Centered overlay content */
  .hero-overlay {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Readable title background */
  .hero-overlay h1 {
    font-size: clamp(2rem, 5vw, 4rem);
    padding: 1rem 2rem;
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(6px);
    border-radius: 12px;
  }

  /* ABOUT */
  .about {
    margin-inline: auto;
    max-width: 1100px;
  }

  .cta {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.75rem 1.25rem;
    background: var(--primary-color);
    color: white;
    border-radius: 8px;
    text-decoration: none;
  }


  .timeline-wrapper {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
  }

  .timeline-section h2 {
    text-align: center;
    margin-bottom: 2rem;
    color: var(--primary-color);
    font-weight: 600;
  }

  @media (max-width: 600px) {
    .hero {
     height: 25vh;
    }
   
  }
</style>

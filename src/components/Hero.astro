---
interface Props {
  title: string;
  subtitle?: string;
  imageSrc?: string;
}

const { title, subtitle, imageSrc, } = Astro.props;
---

<section class={`hero`}>
  {
    imageSrc && (
      <div class="image">
        <img src={imageSrc} alt={title} />
      </div>
    )
  }

  <div class="content">
    <h1>{title}</h1>
    {<p>{subtitle}</p>}
  </div>
</section>

<style>
  /* ======================
     BASE HERO
  ====================== */
  .hero {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ======================
     IMAGE
  ====================== */
  .image img {
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 12px;
    max-width: 800px;
    margin-inline: auto;
  }

  /* ======================
     CONTENT
  ====================== */
  .content {
    padding: 0 1rem 1.5rem;
    text-align: center;
  }
 
</style>

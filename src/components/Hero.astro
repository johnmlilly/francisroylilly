---
interface Props {
  title: string;
  subtitle?: string;
  imageSrc?: string;
}

const { title, subtitle, imageSrc, } = Astro.props;
---

<section class={`hero`}>
  {
    imageSrc && (
      <div class="image">
        <img src={imageSrc} alt={title} />
      </div>
    )
  }

  <div class="content">
    <h1>{title}</h1>
    {<p>{subtitle}</p>}
  </div>
</section>

<style>

  .hero {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .image img {
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .content {
    padding: 0 1rem 1.5rem;
    text-align: center;
  }

@media (min-width: 768px) {
    .image img {
      aspect-ratio: 16 / 9;
      object-fit: cover;
      max-width: 800px;
      margin-inline: auto;
  }
} 
</style>
